---
import { site } from '../data/content';

const levelLabel = (v: number) => {
  if (v >= 90) return 'Expert';
  if (v >= 70) return 'Proficient';
  if (v >= 50) return 'Intermediate';
  return 'Learning';
};

const levelColor = (v: number) => {
  if (v >= 90) return 'bg-lime-100 text-lime-800';
  if (v >= 70) return 'bg-blue-50 text-blue-900';
  return 'bg-stone-100 text-stone-600';
};
---
<section id="skills" class="py-24 md:py-32 px-6 bg-white">
  <div class="max-w-6xl mx-auto">

    <div class="reveal">
      <h2 class="font-display text-4xl md:text-5xl font-black text-stone-900 mb-2">Skills</h2>
      <span class="block h-1 w-14 bg-blue-900 rounded-full mb-12"></span>
    </div>

    <div class="grid md:grid-cols-2 gap-12 md:gap-20">

      <!-- Technical -->
      <div class="reveal reveal-delay-1">
        <h3 class="font-display text-xs font-bold uppercase tracking-widest text-stone-400 mb-8">
          Technical
        </h3>
        <div class="grid grid-cols-2 gap-3">
          {site.skills.technical.map(skill => (
            <div class="bg-stone-50 border border-stone-100 rounded-2xl p-5 flex flex-col gap-3">
              <span class="font-display text-base font-bold text-stone-900 leading-snug">{skill.name}</span>
              <span class={`font-body text-xs font-semibold px-3 py-1 rounded-full self-start ${levelColor(skill.level)}`}>
                {levelLabel(skill.level)}
              </span>
            </div>
          ))}
        </div>

        <div class="mt-10 pt-8 border-t border-stone-100">
          <h3 class="font-display text-xs font-bold uppercase tracking-widest text-stone-400 mb-4">
            Hardware & Tooling
          </h3>
          <div class="flex flex-wrap gap-2">
            {site.skills.hardware.map(h => (
              <span class="bg-blue-50 text-blue-900 text-xs font-medium font-body px-3 py-1.5 rounded-full">
                {h}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Soft skills -->
      <div class="reveal reveal-delay-2">
        <h3 class="font-display text-xs font-bold uppercase tracking-widest text-stone-400 mb-8">
          Human
        </h3>
        <div class="space-y-4">
          {site.skills.soft.map(s => (
            <p class="font-body text-sm text-stone-600 flex gap-2.5 items-start leading-relaxed">
              <span class="text-lime-500 font-bold shrink-0 mt-px">—</span>
              <span>{s}</span>
            </p>
          ))}
        </div>

        <div class="mt-12 p-6 rounded-2xl bg-stone-50 border border-stone-100">
          <p class="font-body text-sm text-stone-500 leading-relaxed italic">
            "If it doesn't work, I will blame the hardware first. Then I will actually read the datasheet."
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

