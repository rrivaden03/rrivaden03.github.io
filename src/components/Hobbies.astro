---
import { site } from '../data/content';
---
<section id="hobbies" class="py-24 md:py-32 px-6 bg-stone-900">
  <div class="max-w-6xl mx-auto">

    <div class="reveal">
      <h2 class="font-display text-4xl md:text-5xl font-black text-white mb-2">Beyond the Code</h2>
      <span class="block h-1 w-14 bg-lime-400 rounded-full mb-4"></span>
      <p class="font-body text-stone-400 mb-12 text-base max-w-lg">
        What keeps me going when the compiler finally stops yelling at me.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {site.hobbies.map((hobby, i) => (
        hobby.image ? (
          /* Photo card */
          <div
            class={`reveal reveal-delay-${(i % 4) + 1} group relative rounded-2xl overflow-hidden transition-transform duration-200 hover:-translate-y-1 cursor-default`}
            style="min-height: 200px;"
          >
            <img
              src={hobby.image}
              alt={hobby.name}
              class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-stone-900/85 via-stone-900/30 to-transparent"></div>
            <div class="relative p-6 md:p-8 flex flex-col justify-end h-full" style="min-height: 200px;">
              <h3 class="font-display text-xl md:text-2xl font-black text-white mb-1">{hobby.name}</h3>
              <p class="font-body text-xs md:text-sm text-white/70 leading-relaxed">{hobby.blurb}</p>
            </div>
          </div>
        ) : (
          /* Color card */
          <div class={`reveal reveal-delay-${(i % 4) + 1} group rounded-2xl p-6 md:p-8 ${hobby.color} transition-transform duration-200 hover:-translate-y-1 cursor-default`}>
            <h3 class="font-display text-xl md:text-2xl font-black mb-2">{hobby.name}</h3>
            <p class="font-body text-xs md:text-sm opacity-70 leading-relaxed">{hobby.blurb}</p>
          </div>
        )
      ))}
    </div>

    <!-- Right Now strip -->
    <div class="reveal mt-10 rounded-2xl bg-stone-800/60 border border-stone-700/50 p-6 md:p-8">
      <div class="flex items-center gap-2 mb-7">
        <span class="w-2 h-2 rounded-full bg-lime-400 animate-pulse shrink-0"></span>
        <span class="font-body text-xs font-bold uppercase tracking-widest text-stone-400">Right Now</span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-0 sm:divide-x sm:divide-stone-700">

        <div class="sm:pr-8">
          <p class="font-body text-xs text-stone-500 uppercase tracking-wider mb-2">Reading</p>
          <p class="font-display font-bold text-white text-lg leading-snug">{site.now.reading.title}</p>
          <span class="inline-block mt-2 mb-2 bg-sky-400/20 text-sky-400 text-sm font-bold font-body px-3 py-1 rounded-full">{site.now.reading.genre}</span>
          <p class="font-body text-stone-400 text-sm">{site.now.reading.author}</p>
          <p class="font-body text-stone-300 text-sm mt-1 italic">{site.now.reading.take}</p>
        </div>

        <div class="sm:px-8">
          <p class="font-body text-xs text-stone-500 uppercase tracking-wider mb-2">Last Watched</p>
          <p class="font-display font-bold text-white text-lg leading-snug">{site.now.watching.title}</p>
          <span class="inline-block mt-2 mb-2 bg-rose-400/20 text-rose-400 text-sm font-bold font-body px-3 py-1 rounded-full">{site.now.watching.genre}</span>
          <p class="font-body text-stone-400 text-sm">{site.now.watching.type}</p>
          <p class="font-body text-stone-300 text-sm mt-1 italic">{site.now.watching.take}</p>
        </div>

        <div class="sm:pl-8">
          <p class="font-body text-xs text-stone-500 uppercase tracking-wider mb-2">On the Court</p>
          <p class="font-display font-bold text-white text-lg leading-snug">{site.now.tennis.status}</p>
          <span class="inline-block mt-2 mb-2 bg-lime-400/20 text-lime-400 text-sm font-bold font-body px-3 py-1 rounded-full">{site.now.tennis.record}</span>
          <p class="font-body text-stone-400 text-sm">{site.now.tennis.note}</p>
        </div>

      </div>
    </div>

  </div>
</section>
