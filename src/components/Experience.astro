---
import { site } from '../data/content';
---
<section id="experience" class="py-24 md:py-32 px-6">
  <div class="max-w-4xl mx-auto">

    <div class="reveal">
      <h2 class="font-display text-4xl md:text-5xl font-black text-stone-900 mb-2">Experience</h2>
      <span class="block h-1 w-14 bg-blue-900 rounded-full mb-6"></span>
      <p class="font-body text-stone-500 text-base leading-relaxed max-w-2xl mb-10">{site.experienceIntro}</p>
    </div>

    <div class="reveal reveal-delay-1">
      <div class="relative">
        <div class="absolute left-4 top-2 bottom-0 w-px bg-stone-200"></div>

        {site.experience.map((job, i) => (
          <div class={`relative pl-10 sm:pl-14 ${i < site.experience.length - 1 ? 'pb-14' : ''}`}>
            <!-- Timeline dot -->
            <div class={`absolute left-0 top-1 w-8 h-8 rounded-full flex items-center justify-center shadow-sm border-4 border-stone-50 ${job.current ? 'bg-blue-900' : 'bg-stone-300'}`}></div>

            <div class="bg-white border border-stone-100 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                <h3 class="font-display text-lg font-bold text-stone-900">{job.company}</h3>
                <div class="flex gap-2 flex-wrap">
                  {job.current && (
                    <span class="bg-lime-100 text-lime-700 text-xs font-semibold px-3 py-1 rounded-full">Current</span>
                  )}
                  {job.tenureNote && (
                    <span class="bg-stone-100 text-stone-500 text-xs font-medium px-3 py-1 rounded-full">{job.tenureNote}</span>
                  )}
                </div>
              </div>
              <p class="font-body text-blue-800 text-sm font-semibold mb-1">{job.role}</p>
              <p class="font-body text-stone-400 text-xs mb-4">{job.location} · {job.period}</p>

              <ul class="space-y-1.5 mb-4">
                {job.bullets.map(b => (
                  <li class="font-body text-sm text-stone-600 flex gap-2 items-baseline">
                    <span class="text-blue-300 shrink-0">›</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2">
                {job.tags.hw.map(tag => (
                  <span class="bg-blue-50 text-blue-900 text-xs px-3 py-1 rounded-full font-body">{tag}</span>
                ))}
                {job.tags.sw.map(tag => (
                  <span class="bg-stone-100 text-stone-600 text-xs px-3 py-1 rounded-full font-body">{tag}</span>
                ))}
                {job.tags.proto.map(tag => (
                  <span class="bg-sky-50 text-sky-700 text-xs px-3 py-1 rounded-full font-body">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Side Projects -->
    <div class="reveal mt-16 pt-16 border-t border-stone-200">
      <h3 class="font-display text-xs font-bold uppercase tracking-widest text-stone-400 mb-8">Side Projects</h3>

      <div class="space-y-6">
        {site.projects.map(project => (
          <div class="bg-white border border-stone-100 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-start justify-between gap-4 mb-5">
              <span class="flex items-center gap-1.5 bg-lime-100 text-lime-700 text-xs font-semibold px-3 py-1 rounded-full">
                <span class="w-1.5 h-1.5 rounded-full bg-lime-500 animate-pulse"></span>
                {project.status}
              </span>
              <a
                href={project.url}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-1.5 text-sm font-medium font-body text-stone-500 hover:text-blue-900 transition-colors"
              >
                Visit site
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
            <h4 class="font-display text-xl font-bold text-stone-900 mb-3">{project.name}</h4>
            <p class="font-body text-stone-600 text-sm md:text-base leading-relaxed mb-5">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.stack.map(tag => (
                <span class="bg-blue-50 text-blue-900 text-xs font-medium font-body px-3 py-1.5 rounded-full">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

