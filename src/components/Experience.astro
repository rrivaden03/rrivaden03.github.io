---
import { site } from '../data/content';
---
<section id="experience" class="py-24 md:py-32 px-6">
  <div class="max-w-4xl mx-auto">

    <div class="reveal">
      <h2 class="font-display text-4xl md:text-5xl font-black text-stone-900 mb-2">Experience</h2>
      <span class="block h-1 w-14 bg-blue-900 rounded-full mb-10"></span>

      <!-- Tabs -->
      <div class="flex gap-2 mb-14">
        <button
          data-tab="work"
          class="tab-btn px-5 py-2 rounded-full text-sm font-medium font-body transition-colors bg-blue-900 text-white"
        >
          Work
        </button>
        <button
          data-tab="education"
          class="tab-btn px-5 py-2 rounded-full text-sm font-medium font-body transition-colors text-stone-500 hover:text-stone-800"
        >
          Education
        </button>
      </div>
    </div>

    <!-- Work panel -->
    <div data-panel="work" class="reveal reveal-delay-1">
      <div class="relative">
        <div class="absolute left-4 top-2 bottom-0 w-px bg-stone-200"></div>

        {site.experience.map((job, i) => (
          <div class={`relative pl-14 ${i < site.experience.length - 1 ? 'pb-14' : ''}`}>
            <!-- Timeline dot -->
            <div class={`absolute left-0 top-1 w-8 h-8 rounded-full flex items-center justify-center shadow-sm border-4 border-stone-50 ${job.current ? 'bg-blue-900' : 'bg-stone-300'}`}></div>

            <div class="bg-white border border-stone-100 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                <h3 class="font-display text-lg font-bold text-stone-900">{job.company}</h3>
                {job.current && (
                  <span class="bg-lime-100 text-lime-700 text-xs font-semibold px-3 py-1 rounded-full">Current</span>
                )}
              </div>
              <p class="font-body text-blue-800 text-sm font-semibold mb-1">{job.role}</p>
              <p class="font-body text-stone-400 text-xs mb-4">{job.location} · {job.period}</p>

              <ul class="space-y-1.5 mb-4">
                {job.bullets.map(b => (
                  <li class="font-body text-sm text-stone-600 flex gap-2">
                    <span class="text-blue-300 mt-1 shrink-0">›</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2">
                {job.tags.hw.map(tag => (
                  <span class="bg-blue-50 text-blue-900 text-xs px-3 py-1 rounded-full font-body">{tag}</span>
                ))}
                {job.tags.sw.map(tag => (
                  <span class="bg-stone-100 text-stone-600 text-xs px-3 py-1 rounded-full font-body">{tag}</span>
                ))}
                {job.tags.proto.map(tag => (
                  <span class="bg-sky-50 text-sky-700 text-xs px-3 py-1 rounded-full font-body">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Education panel -->
    <div data-panel="education" class="hidden reveal reveal-delay-1">
      <div class="relative">
        <div class="absolute left-4 top-2 bottom-0 w-px bg-stone-200"></div>

        {site.education.map(edu => (
          <div class="relative pl-14">
            <div class="absolute left-0 top-1 w-8 h-8 rounded-full bg-lime-400 flex items-center justify-center shadow-sm border-4 border-stone-50"></div>

            <div class="bg-white border border-stone-100 rounded-2xl p-6 shadow-sm">
              <h3 class="font-display text-lg font-bold text-stone-900 mb-1">{edu.school}</h3>
              <p class="font-body text-blue-800 text-sm font-semibold mb-1">{edu.degree}</p>
              <p class="font-body text-stone-400 text-xs mb-4">{edu.location} · {edu.period}</p>
              <ul class="space-y-1.5">
                {edu.bullets.map(b => (
                  <li class="font-body text-sm text-stone-600 flex gap-2">
                    <span class="text-lime-400 mt-1 shrink-0">›</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;

      tabs.forEach(t => {
        const isActive = t.dataset.tab === target;
        t.classList.toggle('bg-blue-900', isActive);
        t.classList.toggle('text-white', isActive);
        t.classList.toggle('text-stone-500', !isActive);
        t.classList.toggle('hover:text-stone-800', !isActive);
      });

      panels.forEach(p => {
        p.classList.toggle('hidden', p.dataset.panel !== target);
      });
    });
  });
</script>
