---
import { site } from '../data/content';
---
<section id="contact" class="py-24 md:py-32 px-6">
  <div class="max-w-2xl mx-auto text-center">

    <div class="reveal">
      <h2 class="font-display text-4xl md:text-5xl font-black text-stone-900 mb-2">Let's Connect</h2>
      <span class="block h-1 w-14 bg-blue-900 rounded-full mx-auto mb-6"></span>
      <p class="font-body text-stone-500 mb-10 text-base leading-relaxed">
        Whether it's about firmware, a tennis match, or just saying hi —
        my inbox is always open.
      </p>

      <a
        href={`mailto:${site.email}`}
        class="inline-block font-display text-xl md:text-2xl font-bold text-stone-900 hover:text-blue-900 transition-colors underline underline-offset-4 decoration-blue-200 hover:decoration-blue-900 mb-12"
      >
        {site.email}
      </a>
    </div>

    <div class="reveal reveal-delay-2 flex justify-center gap-5 flex-wrap">

      <a href={site.social.github} target="_blank" rel="noopener" aria-label="GitHub"
        class="w-12 h-12 rounded-full bg-stone-100 hover:bg-stone-900 text-stone-600 hover:text-white flex items-center justify-center transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>

      <a href={site.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn"
        class="w-12 h-12 rounded-full bg-stone-100 hover:bg-blue-600 text-stone-600 hover:text-white flex items-center justify-center transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>

      <a href={site.social.twitter} target="_blank" rel="noopener" aria-label="Twitter / X"
        class="w-12 h-12 rounded-full bg-stone-100 hover:bg-stone-900 text-stone-600 hover:text-white flex items-center justify-center transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>

      <a href={site.social.twitch} target="_blank" rel="noopener" aria-label="Twitch"
        class="w-12 h-12 rounded-full bg-stone-100 hover:bg-violet-600 text-stone-600 hover:text-white flex items-center justify-center transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/>
        </svg>
      </a>

    </div>

  </div>
</section>

<footer class="py-8 border-t border-stone-100 text-center">
  <p class="font-body text-xs text-stone-400">
    Built with Astro & Tailwind CSS · {new Date().getFullYear()}
  </p>
</footer>
