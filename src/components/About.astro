---
import { site } from '../data/content';
---
<section id="about" class="py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">

    <!-- Text -->
    <div class="reveal">
      <h2 class="font-display text-4xl md:text-5xl font-black text-stone-900 mb-2">About Me</h2>
      <span class="block h-1 w-14 bg-blue-900 rounded-full mb-8"></span>

      <div class="space-y-4 text-stone-600 leading-relaxed text-base md:text-lg">
        {site.about.map(p => <p>{p}</p>)}
      </div>

      <div class="mt-8 flex flex-wrap gap-2">
        <span class="bg-blue-50 text-blue-900 px-4 py-1.5 rounded-full text-sm font-medium font-body">
          🇻🇪 Venezuelan
        </span>
        <span class="bg-stone-100 text-stone-700 px-4 py-1.5 rounded-full text-sm font-medium font-body">
          🇮🇪 Based in Ireland
        </span>
        <span class="bg-lime-100 text-lime-700 px-4 py-1.5 rounded-full text-sm font-medium font-body">
          IoT & Firmware
        </span>
        <span class="bg-sky-100 text-sky-700 px-4 py-1.5 rounded-full text-sm font-medium font-body">
          AWS Cloud
        </span>
        <span class="bg-stone-100 text-stone-700 px-4 py-1.5 rounded-full text-sm font-medium font-body">
          🇻🇪 Native Spanish
        </span>
        <span class="bg-stone-100 text-stone-700 px-4 py-1.5 rounded-full text-sm font-medium font-body">
          🇺🇸 Native-level English
        </span>
        <span class="bg-stone-100 text-stone-700 px-4 py-1.5 rounded-full text-sm font-medium font-body">
          🇩🇪 Learning German
        </span>
      </div>
    </div>

    <!-- Photo -->
    <div class="reveal reveal-delay-2 flex flex-col items-center md:items-end gap-6">
      <div class="relative">
        <!-- Offset decorative circle -->
        <div class="absolute -bottom-3 -right-3 w-full h-full rounded-full bg-blue-100"></div>
        <!-- Navy ring -->
        <div class="absolute inset-0 rounded-full ring-4 ring-blue-900/10 z-10 pointer-events-none"></div>
        <div class="relative w-64 h-64 sm:w-72 sm:h-72 md:w-80 md:h-80 rounded-full overflow-hidden bg-stone-200 shadow-xl">
          <img
            src="/profile.jpg"
            alt="Romina Rivadeneira"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover object-[50%_50%]"
          />
        </div>
      </div>

      <!-- Personal facts card -->
      <div class="w-64 sm:w-72 md:w-80 bg-stone-50 border border-stone-200 rounded-2xl px-5 py-4 space-y-2.5">
        {site.personalFacts.map(fact => (
          <p class="font-body text-sm text-stone-600 flex gap-2.5 items-start">
            <span class="text-lime-500 font-bold shrink-0 mt-px">—</span>
            <span>{fact}</span>
          </p>
        ))}
      </div>
    </div>

  </div>

  <!-- Life journey -->
  <div class="reveal max-w-6xl mx-auto mt-12 pt-10 border-t border-stone-100">
    <p class="font-body text-sm text-stone-400 italic mb-10">{site.journey.tagline}</p>

    <!-- Desktop horizontal timeline -->
    <div class="hidden sm:grid grid-cols-4 relative">
      <div class="absolute left-[12.5%] right-[12.5%] top-[18px] h-px bg-stone-200 z-0"></div>
      {site.journey.stops.map(stop => (
        <div class="relative flex flex-col items-center text-center px-4">
          <div class={`relative z-10 w-9 h-9 rounded-full flex items-center justify-center text-base mb-4 border-2 ${stop.current ? 'bg-blue-900 border-blue-900 ring-4 ring-blue-100' : 'bg-white border-stone-200'}`}>
            {stop.flag}
          </div>
          <div class="flex items-center justify-center gap-1.5 flex-wrap mb-0.5">
            <p class="font-display font-bold text-stone-900 text-sm">{stop.city}</p>
            {stop.home && <span class="font-body text-xs bg-stone-100 text-stone-500 px-2 py-0.5 rounded-full">home</span>}
            {stop.current && <span class="font-body text-xs bg-lime-100 text-lime-700 px-2 py-0.5 rounded-full">now</span>}
          </div>
          <p class="font-body text-xs text-stone-400 mb-3">{stop.country}</p>
          <p class="font-body text-xs text-stone-500 leading-relaxed">{stop.note}</p>
        </div>
      ))}
    </div>

    <!-- Mobile vertical timeline -->
    <div class="sm:hidden relative pl-8">
      <div class="absolute left-[18px] top-0 bottom-0 w-px bg-stone-200"></div>
      <div class="space-y-8">
        {site.journey.stops.map(stop => (
          <div class="relative flex gap-4">
            <div class={`absolute -left-8 top-0.5 w-9 h-9 rounded-full flex items-center justify-center text-base shrink-0 border-2 ${stop.current ? 'bg-blue-900 border-blue-900 ring-4 ring-blue-100' : 'bg-white border-stone-200'}`}>
              {stop.flag}
            </div>
            <div class="pl-4">
              <div class="flex items-center gap-1.5 mb-0.5">
                <p class="font-display font-bold text-stone-900 text-sm">{stop.city}</p>
                {stop.home && <span class="font-body text-xs bg-stone-100 text-stone-500 px-2 py-0.5 rounded-full">home</span>}
                {stop.current && <span class="font-body text-xs bg-lime-100 text-lime-700 px-2 py-0.5 rounded-full">now</span>}
              </div>
              <p class="font-body text-xs text-stone-400 mb-1">{stop.country}</p>
              <p class="font-body text-xs text-stone-500 leading-relaxed">{stop.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

</section>
