---
import { site } from '../data/content';
---
<section id="projects" class="py-24 md:py-32 px-6 bg-white">
  <div class="max-w-6xl mx-auto">

    <div class="reveal">
      <h2 class="font-display text-4xl md:text-5xl font-black text-stone-900 mb-2">Projects</h2>
      <span class="block h-1 w-14 bg-blue-900 rounded-full mb-12"></span>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-6">
      {site.projects.map((project, i) => (
        <div class={`reveal reveal-delay-${(i % 3) + 1} group bg-stone-50 hover:bg-white border border-stone-100 hover:border-blue-200 rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-lg`}>

          <!-- Thumbnail -->
          <div class="h-48 bg-stone-200 overflow-hidden relative">
            <img
              src={`/projects/${project.folder}/thumb.jpg`}
              alt={project.name}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              onerror="this.style.display='none'"
            />
            <!-- Fallback gradient when no image -->
            <div class="absolute inset-0 bg-gradient-to-br from-stone-200 to-stone-300 flex items-center justify-center">
              <span class="font-display text-4xl font-black text-stone-400 opacity-50">
                {project.name.charAt(0)}
              </span>
            </div>
          </div>

          <!-- Content -->
          <div class="p-6">
            <h3 class="font-display text-lg font-bold text-stone-900 mb-2 group-hover:text-blue-900 transition-colors">
              {project.name}
            </h3>
            <p class="font-body text-sm text-stone-500 mb-4 leading-relaxed">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="bg-stone-100 group-hover:bg-blue-50 text-stone-600 text-xs px-3 py-1 rounded-full font-body transition-colors">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
