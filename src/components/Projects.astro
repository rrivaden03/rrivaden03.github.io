---
import { site } from '../data/content';
---
<section id="projects" class="pt-0 pb-24 md:pb-32 px-6 bg-stone-50">
  <div class="max-w-6xl mx-auto">

    <div class="reveal">
      <h2 class="font-display text-4xl md:text-5xl font-black text-stone-900 mb-2">Side Projects</h2>
      <span class="block h-1 w-14 bg-blue-900 rounded-full mb-10"></span>
    </div>

    <div class="space-y-6">
      {site.projects.map((project, i) => (
        <div class={`reveal reveal-delay-${i + 1} bg-white border border-stone-100 rounded-2xl p-6 md:p-8 shadow-sm hover:shadow-md transition-shadow`}>
          <div class="flex items-start justify-between gap-4 mb-5">
            <span class="flex items-center gap-1.5 bg-lime-100 text-lime-700 text-xs font-semibold px-3 py-1 rounded-full">
              <span class="w-1.5 h-1.5 rounded-full bg-lime-500 animate-pulse"></span>
              {project.status}
            </span>
            <a
              href={project.url}
              target="_blank"
              rel="noopener"
              class="flex items-center gap-1.5 text-sm font-medium font-body text-stone-500 hover:text-blue-900 transition-colors"
            >
              Visit site
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
          </div>

          <h3 class="font-display text-xl font-bold text-stone-900 mb-3">{project.name}</h3>
          <p class="font-body text-stone-600 text-sm md:text-base leading-relaxed mb-5">{project.description}</p>

          <div class="flex flex-wrap gap-2">
            {project.stack.map(tag => (
              <span class="bg-blue-50 text-blue-900 text-xs font-medium font-body px-3 py-1.5 rounded-full">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
