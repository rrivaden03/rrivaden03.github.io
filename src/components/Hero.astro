---
import { site } from '../data/content';
---
<section class="min-h-screen flex flex-col items-center justify-center relative overflow-hidden bg-stone-50 px-6">

  <!-- Subtle dot grid background -->
  <div
    class="absolute inset-0 opacity-30"
    style="background-image: radial-gradient(circle, #d6d3d1 1px, transparent 1px); background-size: 28px 28px;"
  ></div>

  <!-- Accent blobs -->
  <div class="absolute top-1/4 -right-32 w-96 h-96 rounded-full bg-blue-100 blur-3xl opacity-60 pointer-events-none"></div>
  <div class="absolute bottom-1/4 -left-32 w-80 h-80 rounded-full bg-lime-100 blur-3xl opacity-50 pointer-events-none"></div>

  <div class="relative text-center max-w-4xl">
    <div class="flex justify-center mb-6">
      <div class="w-24 h-24 rounded-full overflow-hidden ring-4 ring-white shadow-xl">
        <img
          src="/profile.jpg"
          alt="Romina Rivadeneira"
          loading="eager"
          class="w-full h-full object-cover object-[50%_50%]"
        />
      </div>
    </div>

    <p class="font-body text-stone-400 text-lg mb-3 tracking-wide">Hi, I'm</p>

    <h1 class="font-display font-black leading-none tracking-tight text-stone-900 mb-2"
        style="font-size: clamp(3.5rem, 10vw, 8rem);">
      Romina
    </h1>
    <h1 class="font-display font-black leading-none tracking-tight mb-8"
        style="font-size: clamp(2.2rem, 7vw, 5.5rem); color: #1e3a8a;">
      Rivadeneira
    </h1>

    <div class="flex items-center justify-center gap-3 mb-12 text-stone-500 font-body text-lg md:text-xl h-8">
      <span id="rotating-role" class="transition-opacity duration-300">{site.roles[0]}</span>
    </div>

    <div class="flex flex-wrap gap-4 justify-center">
      <a
        href="#experience"
        class="bg-blue-900 hover:bg-blue-800 text-white px-8 py-3 rounded-full font-medium font-body text-sm transition-colors shadow-md hover:shadow-blue-200"
      >
        See My Journey
      </a>
      <a
        href="#contact"
        class="border-2 border-stone-800 text-stone-800 hover:bg-stone-900 hover:text-white px-8 py-3 rounded-full font-medium font-body text-sm transition-colors"
      >
        Let's Talk
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-40">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </div>
</section>

<script define:vars={{ roles: site.roles }}>
  const el = document.getElementById('rotating-role');
  if (!el) return;
  let idx = 0;

  setInterval(() => {
    el.style.opacity = '0';
    setTimeout(() => {
      idx = (idx + 1) % roles.length;
      el.textContent = roles[idx];
      el.style.opacity = '1';
    }, 300);
  }, 2600);
</script>
