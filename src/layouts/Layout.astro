---
interface Props {
  title?: string;
}
const { title = 'Romina Rivadeneira' } = Astro.props;
const siteUrl = Astro.site ?? new URL('https://rominarivadeneira.com');
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Romina Rivadeneira — Firmware Engineer, IoT Builder, Tennis Fanatic. Venezuelan in Ireland building IoT products at PetSafe Brands." />
    <link rel="preload" as="image" href="/profile.jpg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={siteUrl.href} />
    <meta name="theme-color" content="#1e3a8a" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl.href} />
    <meta property="og:title" content="Romina Rivadeneira — Firmware Engineer" />
    <meta property="og:description" content="Venezuelan in Ireland. Building IoT firmware at PetSafe Brands. Tennis fanatic, avid reader, and photographer." />
    <meta property="og:image" content={new URL('/og.jpg', siteUrl).href} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@RomiRiv" />
    <meta name="twitter:title" content="Romina Rivadeneira — Firmware Engineer" />
    <meta name="twitter:description" content="Venezuelan in Ireland. Building IoT firmware at PetSafe Brands. Tennis fanatic, avid reader, and photographer." />
    <meta name="twitter:image" content={new URL('/og.jpg', siteUrl).href} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Romina Rivadeneira",
      "url": siteUrl.href,
      "jobTitle": "Firmware & IoT Software Engineer",
      "worksFor": { "@type": "Organization", "name": "PetSafe Brands" },
      "sameAs": [
        "https://github.com/rrivaden03",
        "https://www.linkedin.com/in/rrivaden/",
        "https://x.com/RomiRiv"
      ]
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-stone-50 text-stone-900 font-body antialiased">
    <slot />

    <script>
      const revealObserver = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('is-visible'); }),
        { threshold: 0.08 }
      );
      document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
    </script>
  </body>
</html>

<style is:global>
  html { scroll-behavior: smooth; }

  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #fafaf9; }
  ::-webkit-scrollbar-thumb { background: #d6d3d1; border-radius: 3px; }
</style>
